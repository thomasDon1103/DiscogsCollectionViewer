# Copy this file to .env and fill in your real Discogs application credentials.
# Then load it before running the app, e.g. on Windows PowerShell:
#   Get-Content .env | ForEach-Object { if ($_ -match '^(.+?)=(.*)$') { Set-Item -Path "Env:$($Matches[1])" -Value $Matches[2] } }
# or just use python-dotenv / your process manager.

# Discogs application credentials -- create an app at
# https://www.discogs.com/settings/developers
DISCOGS_CONSUMER_KEY=YOUR_DISCOGS_CONSUMER_KEY
DISCOGS_CONSUMER_SECRET=YOUR_DISCOGS_CONSUMER_SECRET

# Where the Vue frontend is served from.
FRONTEND_ORIGIN=http://localhost:5173

# Public URL of this Flask backend. The OAuth callback is
# {BACKEND_BASE_URL}/api/auth/callback and must be allowed by your Discogs
# application configuration.
BACKEND_BASE_URL=http://localhost:5000

# A long random string used to sign Flask session cookies.
FLASK_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET